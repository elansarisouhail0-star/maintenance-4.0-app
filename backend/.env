# =============================================================================
# .env — Variables d'environnement du backend
# ⚠ Ne jamais partager ce fichier publiquement (GitHub etc.)
# =============================================================================

# ─── BASE DE DONNÉES SUPABASE ─────────────────────────────────────────────────
# Trouver ces valeurs dans : Supabase → Settings → Database → Connection string
# Choisir le mode "URI" et copier la chaîne complète
DATABASE_URL=postgresql://postgres:VOTRE_MOT_DE_PASSE@db.VOTRE_ID_PROJET.supabase.co:5432/postgres

# ─── SÉCURITÉ JWT ─────────────────────────────────────────────────────────────
# Clé secrète pour signer les tokens — changer en production
SECRET_KEY=gmao_ensam_casablanca_2024_secret_key

# ─── CONFIGURATION SERVEUR ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
